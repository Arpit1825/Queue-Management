<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Dashboard | Smart Queue Management</title>

    <link rel="stylesheet" href="/css/index.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    >
</head>

<body>

    <header id="header">
    <div class="container nav-container">

        <a href="/dashboard" class="logo" id="nav-logo">
            <svg viewBox="0 0 24 24">
                <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,6V12.4L15.5,15.1L16.25,13.8L12.5,11.6V6H11Z"/>
            </svg>

            SmartQueue
        </a>

        <nav class="nav-menu" id="nav-menu">

            <a href="/dashboard" class="nav-link active">
                Dashboard
            </a>

            <a href="/queue" class="nav-link">
                Queue
            </a>

            <a href="/analytics" class="nav-link">
                Analytics
            </a>

            <a href="/profile" class="nav-link">
                Profile
            </a>

        </nav>

        <div class="nav-actions">

            <button
                class="theme-toggle-btn"
                id="theme-toggle"
            >
                <svg class="sun-icon" viewBox="0 0 24 24">
                    <path d="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18Z"/>
                </svg>

                <svg class="moon-icon" viewBox="0 0 24 24">
                    <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"/>
                </svg>
            </button>

            <span
                style="
                margin-right:12px;
                font-weight:600;
                "
            >
                Welcome,
                <%= user.fullname %>
            </span>

            <a
                href="/logout"
                class="btn btn-secondary"
            >
                Logout
            </a>

        </div>

        <div
            class="mobile-toggle"
            id="mobile-menu-toggle"
        >
            <i class="fas fa-bars"></i>
        </div>

    </div>
</header>

    <section class="section dashboard-showcase">
        <div class="container">

            <div class="section-header">
                <span class="section-tag">
                    Dashboard
                </span>

                <h2 class="section-title">
                    Queue Management Dashboard
                </h2>

                <p class="section-subtitle">
                    Monitor queues, counters and customer flow in real time.
                </p>
            </div>

            <div class="grid grid-2 dashboard-showcase-grid">

                <!-- LEFT PANEL -->

                <div class="live-dashboard-panel" id="live-panel">

                    <div class="panel-header">
                        <div class="panel-title-group">
                            <span class="live-indicator"></span>
                            <span class="panel-title">
                                Active Queue Management System
                            </span>
                        </div>

                        <span class="panel-meta">
                            Status: Operational
                        </span>
                    </div>

                    <div class="panel-body">

                        <!-- Stats -->

                        <div class="dashboard-stats-row">

                            <div class="panel-stat-card">
                                <div class="panel-stat-label">
                                    In Queue
                                </div>

                                <div
                                    class="panel-stat-val"
                                    id="sim-metric-active"
                                >
                                    0
                                </div>
                            </div>

                            <div class="panel-stat-card">
                                <div class="panel-stat-label">
                                    Avg Wait Time
                                </div>

                                <div
                                    class="panel-stat-val"
                                    id="sim-metric-wait"
                                >
                                    0m
                                </div>
                            </div>

                            <div class="panel-stat-card">
                                <div class="panel-stat-label">
                                    Counters Active
                                </div>

                                <div
                                    class="panel-stat-val"
                                    id="sim-metric-counters"
                                >
                                    0/4
                                </div>
                            </div>

                            <div class="panel-stat-card">
                                <div class="panel-stat-label">
                                    Staff Efficiency
                                </div>

                                <div
                                    class="panel-stat-val"
                                    id="sim-metric-staff"
                                >
                                    0%
                                </div>
                            </div>

                        </div>

                        <!-- Queue -->

                        <div class="dashboard-content-split">

                            <div class="panel-sub-card">

                                <div class="panel-sub-title">
                                    Waiting Queue
                                    <span id="queue-size">
                                        Real-time
                                    </span>
                                </div>

                                <div
                                    class="queue-list-items"
                                    id="sim-queue-list"
                                >
                                </div>

                            </div>

                            <div class="panel-sub-card">

                                <div class="panel-sub-title">
                                    Service Counters
                                    <span>
                                        Status Panel
                                    </span>
                                </div>

                                <div
                                    class="counters-list"
                                    id="sim-counters-list"
                                >
                                </div>

                            </div>

                        </div>

                        <!-- Chart -->

                        <div class="analytics-chart-container">

                            <div
                                class="panel-sub-title"
                                style="border:none;margin-bottom:0;"
                            >
                                Customer Traffic Volume
                                <span>
                                    24 Hour Flow Analytics
                                </span>
                            </div>

                            <div class="chart-canvas-wrapper">

                                <canvas
                                    id="sim-chart-canvas"
                                >
                                </canvas>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- RIGHT PANEL -->

                <div class="simulator-controls">

                    <h3>
                        Queue Controls
                    </h3>

                    <p>
                        Generate and serve queue tokens.
                    </p>

                    <div class="sim-form-group">

                        <label
                            class="sim-label"
                            for="sim-service"
                        >
                            Queue Category
                        </label>

                        <select
                            class="sim-select"
                            id="sim-service"
                        >
                            <option value="General">
                                General
                            </option>

                            <option value="VIP">
                                VIP
                            </option>

                            <option value="Billing">
                                Billing
                            </option>

                            <option value="Support">
                                Support
                            </option>

                        </select>

                    </div>

                    <div class="sim-actions">

                        <button
                            class="btn btn-primary"
                            id="sim-btn-generate"
                            style="width:100%;"
                        >
                            <i class="fa-solid fa-ticket"></i>

                            Generate Ticket
                        </button>

                        <button
                            class="btn btn-secondary"
                            id="sim-btn-serve"
                            style="width:100%;"
                        >
                            <i class="fa-solid fa-user-check"></i>

                            Serve Next
                        </button>

                        <button
    class="btn btn-secondary"
    id="sim-btn-complete"
> <i class="fa-solid fa-check"></i>
    Complete Service
</button>
    
              <button
                            class="btn btn-secondary"
                            id="sim-btn-reset"
                            style="width:100%;"
                        >
                            <i class="fa-solid fa-trash"></i>

                            Reset Queue
                        </button>

                    </div>

                </div>

            </div>

        </div>
    </section>

    <script src="/js/index.js"></script>

</body>
</html>