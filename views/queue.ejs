<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Dashboard | Smart Queue Management</title>

    <link rel="stylesheet" href="/css/index.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    >
     <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="p-8">

    <header id="header">
    <div class="container nav-container">

        <a href="/dashboard" class="logo" id="nav-logo">
            <svg viewBox="0 0 24 24">
                <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,6V12.4L15.5,15.1L16.25,13.8L12.5,11.6V6H11Z"/>
            </svg>

            SmartQueue
        </a>

        <nav class="nav-menu" id="nav-menu">

            <a href="/dashboard" class="nav-link active">
                Dashboard
            </a>

            <a href="/queue-management" class="nav-link">
                Queue
            </a>

            <a href="/analytics" class="nav-link">
                Analytics
            </a>

            <a href="/profile" class="nav-link">
                Profile
            </a>

        </nav>

        <div class="nav-actions">

            <button
                class="theme-toggle-btn"
                id="theme-toggle"
            >
                <svg class="sun-icon" viewBox="0 0 24 24">
                    <path d="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18Z"/>
                </svg>

                <svg class="moon-icon" viewBox="0 0 24 24">
                    <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"/>
                </svg>
            </button>
            <a
                href="/logout"
                class="btn btn-secondary"
            >
                Logout
            </a>

        </div>

        <div
            class="mobile-toggle"
            id="mobile-menu-toggle"
        >
            <i class="fas fa-bars"></i>
        </div>

    </div>
</header>
<section class="section">
    <div class="container">

        <div class="analytics-header">

            <span class="analytics-tag">
                Queue
            </span>

            <h2 class="analytics-title">
                Queue Management
            </h2>

            <p class="analytics-subtitle">
                Generate, serve and manage customer tokens.
            </p>

        </div>

        <div class="grid grid-2 dashboard-showcase-grid">

            <div class="panel-sub-card">

                <div class="panel-sub-title">
                    Waiting Queue
                    <span>
                        Live Queue
                    </span>
                </div>

                <div id="queueList">

                </div>

            </div>

            <div class="panel-sub-card">

                <div class="panel-sub-title">
                    Active Counters
                    <span>
                        Status
                    </span>
                </div>

                <div id="counterList">

                </div>

            </div>

        </div>

        <div class="panel-sub-card">

    <div class="panel-sub-title">
        Token Search
        <span>
            Track Queue Status
        </span>
    </div>

    <div style="
        display:flex;
        gap:1rem;
        margin-top:1rem;
    ">

        <input
            type="number"
            id="tokenSearch"
            placeholder="Enter Token Number"
            class="sim-input"
        >

        <button
            id="searchBtn"
            class="btn btn-primary"
        >
            Search
        </button>

    </div>

    <div
        id="searchResult"
        style="margin-top:1rem;"
    >

    </div>

</div>

    </div>
</section><script>

async function loadQueuePage(){

    const res =
    await fetch("/queue/dashboard");

   const data =
await res.json();

    document.getElementById(
        "queueList"
    ).innerHTML =
    data.waiting.map(token => {

        return `
            <div class="queue-list-row">

                <span>
                    Token ${token.tokenNumber}
                </span>

                <span>
                    ${token.serviceType}
                </span>

            </div>
        `;

    }).join('');

    document.getElementById(
        "counterList"
    ).innerHTML =
    data.serving.map(token => {

        return `
            <div class="queue-list-row">

                <span>
                    Counter ${token.counterId}
                </span>

                <span>
                    Token ${token.tokenNumber}
                </span>

            </div>
        `;

    }).join('');

}
document.getElementById(
    "searchBtn"
).addEventListener(
    "click",
    async ()=>{

        const tokenNumber =
        document.getElementById(
            "tokenSearch"
        ).value;

        const res =
        await fetch(
            `/queue/token/${tokenNumber}`
        );

        const data =
        await res.json();

if(!data){

    document.getElementById(
        "searchResult"
    ).innerHTML = `
        <div class="queue-list-row">
            Token not found
        </div>
    `;

    return;
}

        document.getElementById(
            "searchResult"
        ).innerHTML = `
            <div class="queue-dat">
                <div class="queue-list-row">
                <span>
                    Status
                </span>
                <span>
                    ${data.status}
                </span>
            </div>

            <div class="queue-list-row">
                <span>
                    Service
                </span>
                <span>
                    ${data.serviceType}
                </span>
            </div>
<div class="queue-list-row">
    <span>Position</span>
    <span>
        ${
            data.position || "-"
        }
    </span>
</div>
            <div class="queue-list-row">
                <span>
                    Counter
                </span>
                <span>
                    ${
                        data.counterId ||
                        "Not provided"
                    }
                </span>
            </div>
                </div>
        `;

    }
);
loadQueuePage();

</script>



    <script src="/js/index.js"></script>

</body>
</html>