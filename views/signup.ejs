       <a href="/login" class="btn btn-secondary">
    Log In
</a>

<a href="/signup" class="btn btn-primary">
    Sign Up
</a>
      </div>

      <div class="mobile-toggle" id="mobile-menu-toggle" aria-label="Toggle mobile menu" aria-controls="nav-menu">
        <i class="fas fa-bars"></i>
      </div>
    </div>
  </header>
<div class="auth-page">

    <div class="modal-container">

        <h3 style="margin-bottom:8px; padding:4px">Create Account</h3>

        <form action="/signup" method="POST">

            <input
                type="text"
                name="fullname"
                placeholder="Full Name"
                class="form-input"
            style="margin: 5px 4px" required>

            <input
                type="email"
                name="email"
                placeholder="Email"
                class="form-input"
                 style="margin: 5px 4px;"
            required>

            <input
                type="password"
                name="password"
                placeholder="Password"
                class="form-input"
                 style="margin: 5px 4px 15px"
            required>

            <button
                class="btn btn-primary"
                type="submit"
            >
                Signup
            </button>

        </form>

    </div>

</div>
<script src="/js/index.js"></script>
</body>
</html>