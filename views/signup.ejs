</head>
<body>

   <header id="header">
    <div class="container nav-container">
      <a href="#" class="logo" id="nav-logo" aria-label="Smart Queue Homepage">
        <svg viewBox="0 0 24 24">
          <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,6V12.4L15.5,15.1L16.25,13.8L12.5,11.6V6H11Z" />
        </svg>
        SmartQueue
      </a>
      
      <nav class="nav-menu" id="nav-menu" role="navigation">
        <a href="/" class="nav-link active" id="link-hero">Home</a>
        <a href="/#features" class="nav-link" id="link-features">Features</a>
        <a href="/#how-it-works" class="nav-link" id="link-how">How It Works</a>
        <a href="/demo" class="nav-link" id="link-demo">Live Demo</a>
        <a href="/#pricing" class="nav-link" id="link-pricing">Pricing</a>
        <a href="/#faq" class="nav-link" id="link-faq">FAQ</a>
        <a href="/#contact" class="nav-link" id="link-contact">Contact</a>
      </nav>

      <div class="nav-actions">
        <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle dark mode">
          <!-- Sun Icon for Dark Theme -->
          <svg class="sun-icon" viewBox="0 0 24 24">
            <path d="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18M20,8.69V4H15.31L12,0.69L8.69,4H4V8.69L0.69,12L4,15.31V20H8.69L12,23.31L15.31,20H20V15.31L23.31,12L20,8.69Z" />
          </svg>
          <!-- Moon Icon for Light Theme -->
          <svg class="moon-icon" viewBox="0 0 24 24">
            <path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z" />
          </svg>
