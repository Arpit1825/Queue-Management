      </div>

      <div class="mobile-toggle" id="mobile-menu-toggle" aria-label="Toggle mobile menu" aria-controls="nav-menu">
        <i class="fas fa-bars"></i>
      </div>
    </div>
  </header>
<main class="auth-page">

    <div class="modal-container">

        <h3 class="modal-title">
            Request a Live Demo
        </h3>

        <p class="modal-desc">
            Book a 30-minute tailored setup call with our technical coordinators.
        </p>

        <form id="demo-form">

            <div class="form-group">
                <label class="form-label">
                    Full Name
                </label>

                <input
                type="text"
                name="fullname"
                class="form-input"
                placeholder="Jane Smith"
                required>
            </div>

            <div class="form-group">
                <label class="form-label">
                    Work Email
                </label>

                <input
                type="email"
                name="email"
                class="form-input"
                placeholder="jane@clinic.org"
                required>
            </div>

            <div class="form-group">
                <label class="form-label">
                    Office / Branch Size
                </label>

                <select
                name="size"
                class="form-input">

                    <option value="Small">
                        1 - 2 Branches
                    </option>

                    <option value="Medium">
                        3 - 10 Branches
                    </option>

                    <option value="Large">
                        10+ Branches
                    </option>

                </select>
            </div>

            <button
            type="submit"
            class="btn btn-primary"
            style="width:100%">
                Schedule Demo Call
            </button>

        </form>

    </div>

</main>

<script src="/js/index.js"></script>

</body>
</html>